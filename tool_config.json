{
  "known": {
    "hermes": "hermes update",
    "agent": "agent update",
    "opencode": "opencode upgrade",
    "uv": "uv self update && uv tool upgrade --all",
    "firecrawl": "npm update -g firecrawl-cli",
    "mmx": "npm update -g mmx-cli",
    "mmx-cli": "npm update -g mmx-cli",
    "codex": "npm update -g codex-cli",
    "codex-cli": "npm update -g codex-cli",
    "dev-browser": "npm update -g dev-browser",
    "tinyfish": "npm update -g tinyfish",
    "cline": "npm update -g cline",
    "ollama": "ollama update 2>/dev/null || true",
    "warp": "warp-cli update 2>/dev/null || true",
    "gh": "gh auth refresh 2>/dev/null || gh upgrade 2>/dev/null || true",
    "goose": "goose update 2>/dev/null || true",
    "kimi": "kimi update 2>/dev/null || true",
    "kimi-cli": "kimi update 2>/dev/null || true",
    "mise": "mise self-update 2>/dev/null || true",
    "starship": "starship self-update 2>/dev/null || true",
    "zoxide": "zoxide update 2>/dev/null || zoxide self-update 2>/dev/null || true",
    "atuin": "atuin update 2>/dev/null || true",
    "just": "cargo install just --locked 2>/dev/null || true",
    "fzf": "brew upgrade fzf 2>/dev/null || true",
    "lazygit": "brew upgrade lazygit 2>/dev/null || true",
    "bat": "brew upgrade bat 2>/dev/null || true",
    "eza": "cargo install eza --locked 2>/dev/null || true",
    "ripgrep": "brew upgrade ripgrep 2>/dev/null || true",
    "fd": "brew upgrade fd 2>/dev/null || true",
    "yazi": "brew upgrade yazi 2>/dev/null || true"
  },
  "bulk": {
    "npm": "npm update -g --ignore-scripts 2>&1 | grep -v 'cline-4g5O6Ovb' | grep -v 'npm warn' || true",
    "cargo": "cargo install-update -a 2>/dev/null || cargo update",
    "gem": "gem update --user-install 2>&1 | grep -v -E 'BUILD_RUBY_PLATFORM|fiddle|compiling|make:|error:|Error:|warnings generated' || true",
    "brew": "brew update && brew upgrade",
    "manual": "brew upgrade 2>/dev/null || true",
    "conda": "conda update --all -y",
    "uv": "uv self update && uv tool upgrade --all",
    "uv/pip": "uv self update && uv tool upgrade --all",
    "uv/venv": "uv self update && uv tool upgrade --all",
    "fnm": "fnm update 2>/dev/null || true",
    "bun": "bun update 2>/dev/null || true",
    "deno": "deno upgrade 2>/dev/null || true",
    "pyenv": "pyenv update 2>/dev/null || true",
    "rbenv": "brew upgrade rbenv ruby-build 2>/dev/null || true",
    "sdkman": "bash -lc 'test -s \"$HOME/.sdkman/bin/sdkman-init.sh\" && . \"$HOME/.sdkman/bin/sdkman-init.sh\" && sdk selfupdate'",
    "opencode": "opencode upgrade 2>/dev/null || true",
    "go": "go install golang.org/x/tools/gopls@latest 2>/dev/null; go install golang.org/x/tools/cmd/goimports@latest 2>/dev/null || true",
    "dotnet": "dotnet tool update --global 2>/dev/null || true",
    "krew": "kubectl krew upgrade 2>/dev/null || true",
    "mise": "mise self-update 2>/dev/null || true",
    "path": ""
  }
}
